initialize() {
	initializeMutationRate(0);
	initializeMutationType("m0", 0.5, "f", 0.0);
	initializeGenomicElementType("g1", m0, 1);
	m0.convertToSubstitution = F;
	initializeGenomicElement(g1, 0, 1);
	initializeRecombinationRate(0);
	defineConstant("scale", 500);
}
1 late() {
	N0 = 4.252830167e+05;
	N1 = 1.980610000e+00 * N0;
	// pop0
	sim.addSubpop(subpopID="p0",
		size = asInteger(N0 / scale)
		);
	
	// Give inversion in the ancestral population at frequency p_0
	inverted = sample(p0.genomes, asInteger(p_opt_0 * length(p0.genomes)));
	inverted.addNewDrawnMutation(m0, 0);
	sim.addSubpopSplit(subpopID= "p1",
		size= asInteger(N1 / scale),
		sourceSubpop=p0
		);
	// Read migration rates
	lines = readFile("/home/ishigohoka/projects/Miriam/PhD/PhD/inv_freq_abc/output/demography/post_ms_slim/model_2_1_2_posterior_med_mig_for_slim.txt");
	subpops = sim.subpopulations;
	line=lines[0];
	pops = strsplit(strsplit(line, " ")[0], "_")[c(1,2)];
	if(pops[0] < pops[1]){
		mig = asFloat(strsplit(line, " ")[1]);
		p_a = subpops[subpops.id == pops[0]];
		p_b = subpops[subpops.id == pops[1]];
		p_a.setMigrationRates(p_b, mig);
		p_b.setMigrationRates(p_a, mig);
	}
}
