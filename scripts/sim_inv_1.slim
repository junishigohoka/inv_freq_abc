		p_b.setMigrationRates(p_a, mig);
	}
}
390 early(){
	// Read population size ratio
	N0 = 4.252830167e+05;
	lines = readFile("/home/ishigohoka/projects/Miriam/PhD/PhD/inv_freq_abc/output/demography/post_ms_slim/model_2_1_2_posterior_med_N_for_slim.txt");
	for(i in 1:(length(lines)-1)){ //starting from pop2 in the second line (index 1)
		line = lines[i];
		sim.addSubpopSplit(subpopID=paste0(c("p", i+1)),
			size = asInteger(N0 * asFloat(strsplit(line, " ")[1]) / scale),
			sourceSubpop=p0
			);
	
	}
	// Read migration rates
	lines = readFile("/home/ishigohoka/projects/Miriam/PhD/PhD/inv_freq_abc/output/demography/post_ms_slim/model_2_1_2_posterior_med_mig_for_slim.txt");
	subpops = sim.subpopulations;
	for(line in lines){
		pops = strsplit(strsplit(line, " ")[0], "_")[c(1,2)];
		if(pops[0] < pops[1]){
			mig = asFloat(strsplit(line, " ")[1]);
			p_a = subpops[subpops.id == pops[0]];
			p_b = subpops[subpops.id == pops[1]];
			p_a.setMigrationRates(p_b, mig);
			p_b.setMigrationRates(p_a, mig);
		}
	}
}

