	inverted.addNewDrawnMutation(m0, 0);
	sim.addSubpopSplit(subpopID= "p1",
		size= asInteger(N1 / scale),
		sourceSubpop=p0
		);
	// Read migration rates
	lines = readFile("/home/ishigohoka/projects/Miriam/PhD/PhD/inv_freq_abc/output/demography/post_ms_slim/model_2_1_2_posterior_med_mig_for_slim.txt");
	subpops = sim.subpopulations;
