	cat(c(simid, " "));
	ninds_pops = c(0, 12, 66, 12, 23, 10, 13, 13, 11, 9, 10);
	rep = 0;
	pops = sim.subpopulations;
	for(i in 1:(length(pops)-1)){
		//print(i);
		pop = pops[i];
		ninds = ninds_pops[i];
		inds=sample(pop.individuals, ninds);
		cat(c(format("%.2f", sum(inds.genomes.countOfMutationsOfType(m0))/length(inds.genomes)), " "));
	}
	cat("\n");
}
